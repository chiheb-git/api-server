    flexDirection: "row",
    alignItems: "center",
    gap: 6,
  },
  dotCircle: {
    width: 6,
    height: 6,
    borderRadius: 3,
    backgroundColor: "rgba(255,255,255,0.6)",
  },
  dotLabel: {
    color: "rgba(255,255,255,0.8)",
    fontSize: 11,
    fontFamily: "Inter_400Regular",
  },
  actionsRow: {
    flexDirection: "row",
    gap: 14,
    marginBottom: 16,
  },
  actionsRowSingle: {
    marginBottom: 16,
  },
  actionCard: {
